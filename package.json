{
  "name": "neptune-tinker",
  "version": "0.1.0",
  "description": "Neptune-compatible local sandbox using TinkerGraph. Claude-first dev tooling.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "sandbox:start": "docker compose -f scripts/docker-compose.yml up -d --wait",
    "sandbox:stop": "docker compose -f scripts/docker-compose.yml down",
    "sandbox:reset": "docker compose -f scripts/docker-compose.yml down && docker compose -f scripts/docker-compose.yml up -d --wait",
    "sandbox:health": "docker compose -f scripts/docker-compose.yml ps",
    "sandbox:logs": "docker compose -f scripts/docker-compose.yml logs -f",
    "sandbox:console": "docker compose -f scripts/docker-compose.yml run --rm gremlin-console"
  },
  "dependencies": {
    "gremlin": "^3.7.2"
  },
  "devDependencies": {
    "typescript": "^5.5.0",
    "@types/node": "^20.0.0"
  },
  "files": [
    "dist",
    "scripts",
    "skills"
  ]
}
